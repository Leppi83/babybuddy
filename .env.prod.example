# Core Django
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
STATICFILES_USE_MANIFEST=False
ALLOWED_HOSTS=your-domain.tld,your-vm-ip
CSRF_TRUSTED_ORIGINS=https://your-domain.tld
TZ=Europe/Berlin

# App runtime
BABYBUDDY_PORT=8000
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60

# Postgres
POSTGRES_DB=babybuddy
POSTGRES_USER=babybuddy
POSTGRES_PASSWORD=replace-with-a-strong-password
#DATABASE_URL=postgres://babybuddy:replace-with-a-strong-password@postgres:5432/babybuddy

# Optional Ollama explanation
# OLLAMA_ENABLED=1
# OLLAMA_URL=http://ollama:11434
# OLLAMA_MODEL=llama3.1:8b-instruct
# OLLAMA_TIMEOUT_S=2.5

# Feature flags
# Enable new shadcn runtime for /children/<slug>/dashboard/
# DASHBOARD_SHADCN_CHILD_ENABLED=False
# Enable standalone preview route /ui-preview/
# SHADCN_UI_PREVIEW_ENABLED=False
