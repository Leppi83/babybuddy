# Core Django
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
STATICFILES_USE_MANIFEST=False
ALLOWED_HOSTS=your-domain.tld,your-vm-ip
CSRF_TRUSTED_ORIGINS=https://your-domain.tld
TZ=Europe/Berlin

# App runtime
BABYBUDDY_PORT=8000
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60
SERVE_MEDIA=True

# Postgres
POSTGRES_DB=babybuddy
POSTGRES_USER=babybuddy
POSTGRES_PASSWORD=replace-with-a-strong-password
#DATABASE_URL=postgres://babybuddy:replace-with-a-strong-password@postgres:5432/babybuddy

# Optional Ollama explanation
# OLLAMA_ENABLED=1
# OLLAMA_URL=http://ollama:11434
# OLLAMA_MODEL=llama3.1:8b-instruct
# OLLAMA_TIMEOUT_S=2.5

# Web Push Notifications (VAPID)
# Generate keys with: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print('Private:'); print(v.private_pem().decode()); print('Public:'); print(v.public_key)"
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_CLAIMS_EMAIL=mailto:you@example.com

# Feature flags
# Enable new shadcn runtime for /children/<slug>/dashboard/
# DASHBOARD_SHADCN_CHILD_ENABLED=False
